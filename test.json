{
	"info": {
		"name": "Online Job Fair API Testing",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Register User",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Somchai Test\",\n    \"tel\": \"0812345678\",\n    \"email\": \"somchai@test.com\",\n    \"password\": \"password123\",\n    \"role\": \"user\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
			}
		},
		{
			"name": "2. Login User",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.environment.set(\"user_token\", jsonData.token);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"somchai@test.com\",\n    \"password\": \"password123\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
			}
		},
		{
			"name": "3. Create Booking (Session 1)",
			"request": {
				"method": "POST",
				"header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"bookDate\": \"2022-05-10T09:00:00.000Z\",\n    \"company\": \"{{company_id}}\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/companies/{{company_id}}/bookings", "host": ["{{base_url}}"], "path": ["companies", "{{company_id}}", "bookings"] }
			}
		},
		{
			"name": "4. Get My Bookings",
			"request": {
				"method": "GET",
				"header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
				"url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
			}
		},
		{
			"name": "5. Update My Booking",
			"request": {
				"method": "PUT",
				"header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"bookDate\": \"2022-05-11T13:00:00.000Z\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/bookings/{{booking_id}}", "host": ["{{base_url}}"], "path": ["bookings", "{{booking_id}}"] }
			}
		},
		{
			"name": "6. Delete My Booking",
			"request": {
				"method": "DELETE",
				"header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
				"url": { "raw": "{{base_url}}/bookings/{{booking_id}}", "host": ["{{base_url}}"], "path": ["bookings", "{{booking_id}}"] }
			}
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:5000/api/v1" },
		{ "key": "company_id", "value": "ใส่_ID_บริษัทที่นี่" },
		{ "key": "booking_id", "value": "ใส่_ID_การจองที่นี่" }
	]
}